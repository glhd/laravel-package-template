{
  "name": "glhd/laravel-package-template",
  "description": "",
  "keywords": [
    "laravel"
  ],
  "authors": [
    {
      "name": "Chris Morrell",
      "homepage": "http://www.cmorrell.com"
    }
  ],
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">= 8.3",
    "illuminate/support": "^11|^12|^13|14.x-dev|dev-master|dev-main",
    "ext-json": "*"
  },
  "require-dev": {
    "orchestra/testbench": "^9.17|^10.11|^11.1|dev-master|dev-main",
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpunit/phpunit": "^12.5|^13.2"
  },
  "autoload": {
    "psr-4": {
      "Glhd\\LaravelPackageTemplate\\": "src/"
    }
  },
  "autoload-dev": {
    "classmap": [
      "tests/TestCase.php"
    ],
    "psr-4": {
      "Glhd\\LaravelPackageTemplate\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "fix-style": "vendor/bin/php-cs-fixer fix",
    "check-style": "vendor/bin/php-cs-fixer fix --diff --dry-run"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Glhd\\LaravelPackageTemplate\\Support\\LaravelPackageTemplateServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
